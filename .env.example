# Public demo mode for hosted environments (Hugging Face Spaces)
DEMO_MODE=true

# Keep false for public deployments to prevent accidental paid calls.
ALLOW_LIVE_RUNS=false

# When true, live runs require each visitor to provide a session key and
# will not fall back to the host OPENAI_API_KEY secret.
REQUIRE_SESSION_API_KEY=false

# Optional API key for local/private live workflows.
# Leave empty in public repos and Spaces variables unless explicitly needed.
OPENAI_API_KEY=

# Optional config selector default path shown in the UI.
DEFAULT_CONFIG_PATH=evals/config.yaml

# Output directory for generated reports/benchmarks.
REPORTS_DIR=reports

# Benchmark mode label shown in the UI.
BENCHMARK_MODE=demo

# Live run safeguards (used only when ALLOW_LIVE_RUNS=true and DEMO_MODE=false)
LIVE_RUN_MAX_CASES=3
LIVE_RUN_COOLDOWN_SECONDS=60
LIVE_RUN_MAX_RUNS_PER_PROCESS=3
